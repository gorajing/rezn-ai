# Weave
WEAVE_PROJECT=rezn-ai/rezn-ai
WANDB_API_KEY=

# Redis
REDIS_URL=redis://localhost:6379/0

# API
REZN_RUNS_ROOT=./runs

# W&B Inference (LLM agents — uses WANDB_API_KEY above, separate key optional)
WANDB_INFERENCE_API_KEY=

# OpenAI direct fallback (used when WANDB_API_KEY is absent)
OPENAI_API_KEY=

# LLM agents are OFF by default (deterministic, reproducible). Set to 1 to go
# live with W&B Inference / OpenAI for propose_plan + critique.
REZN_ENABLE_INFERENCE=0
