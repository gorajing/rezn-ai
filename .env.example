# Weave
WEAVE_PROJECT=rezn-ai/rezn-ai
WANDB_API_KEY=

# Redis — defaults to Redis Cloud.
# Copy your database's PUBLIC ENDPOINT and DEFAULT-USER PASSWORD from the
# Redis Cloud console: Databases > (your DB) > Connect.
# NOTE: this is the database password, NOT the account-level Cloud API key
# (the API key is only for the management REST API, not for data connections).
#
# Option A — one connection string (use rediss:// when TLS is enabled on the DB):
REDIS_URL=rediss://default:YOUR_DB_PASSWORD@YOUR-ENDPOINT.cloud.redislabs.com:PORT
#
# Option B — discrete fields (used only when REDIS_URL is empty):
# REDIS_HOST=YOUR-ENDPOINT.cloud.redislabs.com
# REDIS_PORT=PORT
# REDIS_USERNAME=default
# REDIS_PASSWORD=YOUR_DB_PASSWORD
# REDIS_TLS=true
#
# Fail fast instead of silently falling back to the in-memory store (production default):
REDIS_REQUIRED=true
#
# For local development with `docker compose up -d redis` instead of the cloud:
# REDIS_URL=redis://localhost:6379/0

# Production posture — master switch for deploy/live use. When true, the API
# refuses local fallbacks (InMemoryStore, LocalTasteMemory, LocalGeneratorEngine,
# deterministic LLM paths) unless REZN_DISABLE_REDIS is set (tests only).
REZN_PRODUCTION=true

# API — clean-room generator engine (set REZN_ENGINE=local only for the simpler
# in-repo placeholder engine; "rezn" is the real default).
REZN_RUNS_ROOT=./runs
REZN_ENGINE=rezn

# W&B Inference (LLM agents). Key priority: WANDB_INFERENCE_API_KEY, then
# WANDB_API_KEY above, then OPENAI_API_KEY below.
WANDB_INFERENCE_API_KEY=

# W&B Models (optional, for W&B Models API access)
WANDB_MODELS_API_KEY=

# OpenAI direct fallback (used when no W&B inference key is set)
OPENAI_API_KEY=

# LLM agents: deterministic fallback by default. Set to 1 to go live with W&B
# Inference / OpenAI for propose_plan + critique (production: 1).
REZN_ENABLE_INFERENCE=1

# Live inference is required in production — LLM errors fail the request instead
# of silently degrading to keyword/deterministic paths.
REZN_INFERENCE_REQUIRED=true

# Producer Taste Memory — Redis Cloud Agent Memory service (Redis Iris).
# Create the service in the Redis Cloud console (Agent Memory → Quick create), then
# copy its connection details here. The managed API is authenticated with a Bearer
# service key and scoped to a Store ID (https://ENDPOINT/v1/stores/STORE_ID/...).
#   AGENT_MEMORY_URL       = the service Endpoint / API Base URL
#   AGENT_MEMORY_STORE_ID  = the Store ID (General settings)
#   AGENT_MEMORY_API_KEY   = the service API key (shown once at creation)
AGENT_MEMORY_URL=
AGENT_MEMORY_STORE_ID=
AGENT_MEMORY_API_KEY=
AGENT_MEMORY_NAMESPACE=rezn-taste
AGENT_MEMORY_PRODUCER_ID=default
# Production posture: no local fallback. The API refuses to start unless the Agent
# Memory service above is configured and reachable.
AGENT_MEMORY_REQUIRED=true
