# Vercel → frontend (Next.js) environment variables.
# Set these in Vercel → Project → Settings → Environment Variables (Production).

# Public base URL of the FastAPI backend on Railway. NEXT_PUBLIC_* is inlined at
# BUILD time, so set this before deploying (redeploy if the backend URL changes).
NEXT_PUBLIC_API_URL=https://YOUR-BACKEND.up.railway.app

# Server-side key for the CopilotKit runtime route (app/api/copilotkit/route.ts).
# Without it the copilot chat returns a clean 503; the rest of the app still works.
OPENAI_API_KEY=
