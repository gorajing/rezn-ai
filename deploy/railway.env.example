# Railway → backend (FastAPI) environment variables.
# Set these in Railway → your service → Variables. Copy the secret VALUES from your
# local .env (never commit real secrets). This file documents WHICH vars to set.

# ── Redis Cloud (live state + learned memory) ─────────────────────────────────
REDIS_URL=                       # your Redis Cloud rediss://default:PW@host:port URL
REDIS_REQUIRED=true              # fail fast if Redis is unreachable (no silent fallback)

# ── Weave / W&B tracing ───────────────────────────────────────────────────────
WANDB_API_KEY=
WEAVE_PROJECT=rezn-ai/rezn-ai

# ── LLM inference (composer plan + critic panel) ──────────────────────────────
OPENAI_API_KEY=
REZN_ENABLE_INFERENCE=1
REZN_INFERENCE_REQUIRED=true     # LLM errors fail the request instead of degrading

# ── Production posture (master switch) ────────────────────────────────────────
REZN_PRODUCTION=true

# ── Producer taste memory (Redis Agent Memory / Iris) ─────────────────────────
AGENT_MEMORY_URL=
AGENT_MEMORY_STORE_ID=
AGENT_MEMORY_API_KEY=
AGENT_MEMORY_NAMESPACE=rezn-taste
AGENT_MEMORY_PRODUCER_ID=default
# Resilient: degrade to the local taste fallback if the managed service is down,
# rather than refusing to boot. (Set true for the strict full-fidelity posture.)
AGENT_MEMORY_REQUIRED=false

# ── Rate limiting (per client IP, on the LLM-spending endpoints) ───────────────
REZN_RATE_LIMIT_PER_MIN=5
REZN_RATE_LIMIT_PER_DAY=50
# REZN_RATE_LIMIT_DISABLED=true   # uncomment to turn limiting off entirely

# ── CORS — set to your deployed Vercel origin once the frontend is live ────────
REZN_CORS_ORIGINS=https://YOUR-APP.vercel.app

# ── Ephemeral run-state TTL (seconds); learned policy never expires ───────────
REZN_STATE_TTL_SECONDS=604800
