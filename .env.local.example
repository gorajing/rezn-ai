# Frontend (Next.js / CopilotKit) environment.
# Copy this file to .env.local and fill in the values:
#   cp .env.local.example .env.local
#
# .env.local is git-ignored and stays on your machine.

# Required for the CopilotKit copilot to generate responses.
# Read server-side by app/api/copilotkit/route.ts (OpenAIAdapter).
# Without it the app still runs, but the chat returns a 503 until it is set.
OPENAI_API_KEY=

# Optional: disable CopilotKit's anonymous runtime telemetry.
# COPILOTKIT_TELEMETRY_DISABLED=true
