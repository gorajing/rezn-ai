# Frontend (Next.js / CopilotKit) environment.
# Copy this file to .env.local and fill in the values:
#   cp .env.local.example .env.local
#
# .env.local is git-ignored and stays on your machine.

# Preferred for the CopilotKit copilot to generate responses through W&B
# Inference (OpenAI-compatible, Weave-visible sponsor path).
WANDB_INFERENCE_API_KEY=
WANDB_API_KEY=
WEAVE_PROJECT=rezn-ai/rezn-ai

# Fallback when no W&B key is set.
# Read server-side by app/api/copilotkit/route.ts (OpenAIAdapter).
# Without any of these keys the app still runs, but the chat returns a 503.
OPENAI_API_KEY=

# Optional: disable CopilotKit's anonymous runtime telemetry.
# COPILOTKIT_TELEMETRY_DISABLED=true

# REZN backend API (FastAPI). The Control Room calls this for batches, curation,
# refine, and preview audio. Defaults to local uvicorn; set to the deployed URL
# in production. Must be reachable from the browser (NEXT_PUBLIC_ = client-side).
NEXT_PUBLIC_API_URL=http://localhost:8000
